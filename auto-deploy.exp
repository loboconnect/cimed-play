#!/usr/bin/expect -f

# Script automatizado para deploy na Vercel
# Responde automaticamente aos prompts

spawn vercel --prod

# Aguardar e responder aos prompts
expect "Set up and deploy" { send "yes\r" }
expect "Which scope" { send "\r" }
expect "Link to existing project" { send "no\r" }
expect "What's your project's name" { send "campanha-digital-2026\r" }
expect "In which directory is your code located" { send "\r" }

# Aguardar o fim do deploy
expect eof