generator client {
      provider = "prisma-client-js"
}

datasource db {
      provider = "postgresql"
        url      = env("DATABASE_URL")
}

model User {
      id        String   @id @default(cuid())
        email     String   @unique
          role      String
            createdAt DateTime @default(now())
}

model LogAuditoria {
      id             String   @id @default(cuid())
        userId         String
          acao_detalhada String
            ip_origem      String
              dado_antes     String
                dado_depois    String
                  createdAt      DateTime @default(now())
}
